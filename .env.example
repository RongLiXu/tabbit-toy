# 从已登录的 Tabbit 浏览器导出 web.tabbit.ai 域下的 Cookie 字符串
# 导出方法：用 cookie-helper-extension 扩展一键导出（含 HttpOnly）
TABBIT_COOKIE=

# 可选：覆盖默认签名 key（默认 f8d0e6a73f8d4b1a9c3d2e1f9a4b7c6d）
# 一般留空，脚本会自动从 /chat/sign-key 拉取
TABBIT_SIGN_KEY=

# Tabbit 版本号（用于 x-req-ctx 头）
# 实测真实格式：来自 chrome.tabInstance.getDeviceInfo().tabbitVersion，带括号构建号
TABBIT_VERSION=1.1.39(10101039)

# 探测时用的测试模型 ID（留空则用 Default）
# 实测：模型列表里没有 model_id 字段，selected_model 直接用 display_name
TABBIT_TEST_MODEL=Default

# ─── 代理服务配置（src/server.mjs）─────────────────────────
# HTTP 服务端口
PORT=8787

# 可选：保护代理端点的 API Key（客户端用 Authorization: Bearer <KEY>）
# 留空则不鉴权
API_KEY=

# ─── Docker 部署配置（scripts/deploy.sh）───────────────────
# Docker Hub 用户名（留空则跳过 Docker Hub 推送）
DOCKERHUB_USER=

# GitHub 用户名（留空则从 git remote 推断）
GHCR_USER=

# 镜像名（默认 tabbit2api）
# IMAGE_NAME=tabbit2api

# 镜像标签（默认读取 package.json 版本号）
# IMAGE_TAG=

# 远程部署目标（如 root@1.2.3.4）
# DEPLOY_HOST=

# 远程部署目录（默认 ~/tabbit2api）
# DEPLOY_DIR=~/tabbit2api
